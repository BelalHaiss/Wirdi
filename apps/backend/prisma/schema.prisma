generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
  // generatedFileExtension = "ts" // we need this when run tests 
  // importFileExtension = "ts" // we need this when run tests
}

datasource db {
  provider = "mysql"
}

model User {
  id             String   @id @default(ulid())
  username       String   @unique @db.VarChar(50)
  name           String   @db.VarChar(100)
  nameNormalized String?  @map("name_normalized") @db.VarChar(100)
  password       String   @db.VarChar(255)
  role           UserRole
  timezone       String   @default("Africa/Cairo") @db.VarChar(50)
  notes          String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Group moderator relation
  moderatedGroups Group[] @relation("GroupModerator")

  // GroupMember relations (student enrolled, or listed as mate)
  groupMemberships   GroupMember[] @relation("GroupMemberStudent")
  mateInMemberships  GroupMember[] @relation("GroupMemberMate")
  removedMemberships GroupMember[] @relation("GroupMemberRemovedBy")

  // StudentWird relations (owns the wird, or is the mate read upon)
  studentWirds StudentWird[] @relation("StudentWirdOwner")
  wirdReadUpon StudentWird[] @relation("StudentWirdMate")

  // Request relations (student making request, or moderator reviewing)
  submittedRequests Request[] @relation("RequestStudent")
  reviewedRequests  Request[] @relation("RequestReviewer")

  // Excuse relations
  excusesAsStudent Excuse[] @relation("ExcuseStudent")
  excusesCreated   Excuse[] @relation("ExcuseCreator")

  // Alert relations
  alerts        Alert[]        @relation("AlertStudent")
  notifications Notification[]

  @@index([role])
  @@index([nameNormalized])
  @@map("users")
}

model Group {
  id          String      @id @default(ulid())
  name        String      @db.VarChar(100)
  timezone    String      @default("Asia/Riyadh") @db.VarChar(50)
  createdAt   DateTime    @default(now()) @map("created_at")
  awrad       Json // array ["wird1", "wird2", ...]
  moderatorId String?     @map("moderator_id")
  status      GroupStatus @default(ACTIVE)
  description String?     @db.VarChar(500)

  moderator User?         @relation("GroupModerator", fields: [moderatorId], references: [id], onDelete: SetNull)
  members   GroupMember[]
  weeks     Week[]
  requests  Request[]
  excuses   Excuse[]
  alerts    Alert[]

  @@index([moderatorId])
  @@index([status])
  @@map("groups")
}

model GroupMember {
  id        String            @id @default(ulid())
  groupId   String            @map("group_id")
  studentId String            @map("student_id")
  mateId    String?           @map("mate_id")
  status    GroupMemberStatus @default(ACTIVE)
  joinedAt  DateTime          @default(now()) @map("joined_at")
  removedAt DateTime?         @map("removed_at")
  removedBy String?           @map("removed_by")

  group         Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student       User  @relation("GroupMemberStudent", fields: [studentId], references: [id], onDelete: Cascade)
  mate          User? @relation("GroupMemberMate", fields: [mateId], references: [id], onDelete: SetNull)
  removedByUser User? @relation("GroupMemberRemovedBy", fields: [removedBy], references: [id], onDelete: SetNull)

  @@unique([groupId, studentId])
  @@index([studentId])
  @@index([mateId])
  @@index([removedAt])
  @@index([removedBy])
  @@map("group_members")
}

model Week {
  id         String   @id @default(ulid())
  groupId    String   @map("group_id")
  weekNumber Int      @map("week_number")
  startDate  DateTime @map("start_date") @db.Date
  endDate    DateTime @map("end_date") @db.Date
  createdAt  DateTime @default(now()) @map("created_at")

  group         Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  scheduleImage ScheduleImage?
  studentWirds  StudentWird[]
  alerts        Alert[]

  @@unique([groupId, weekNumber])
  @@unique([groupId, startDate])
  @@index([groupId])
  @@map("weeks")
}

model ScheduleImage {
  id             String   @id @default(ulid())
  weekId         String   @unique @map("week_id")
  name           String   @db.VarChar(100)
  imageUrl       String   @map("image_url") @db.VarChar(500)
  imagekitFileId String   @map("imagekit_file_id") @db.VarChar(500)
  createdAt      DateTime @default(now()) @map("created_at")

  week Week @relation(fields: [weekId], references: [id], onDelete: Cascade)

  @@map("schedule_images")
}

model StudentWird {
  id           String         @id @default(ulid())
  studentId    String         @map("student_id")
  weekId       String         @map("week_id")
  dayNumber    Int            @map("day_number") @db.TinyInt
  status       WirdStatus
  readSource   ReadSourceType @default(DEFAULT_GROUP_MATE) @map("read_source")
  readOnMateId String?        @map("read_on_mate_id")
  recordedAt   DateTime       @map("recorded_at")

  student    User  @relation("StudentWirdOwner", fields: [studentId], references: [id], onDelete: Cascade)
  week       Week  @relation(fields: [weekId], references: [id], onDelete: Cascade)
  readOnMate User? @relation("StudentWirdMate", fields: [readOnMateId], references: [id], onDelete: SetNull)

  @@unique([studentId, weekId, dayNumber])
  @@index([studentId])
  @@index([weekId])
  @@map("student_wirds")
}

model Request {
  id         String        @id @default(ulid())
  studentId  String        @map("student_id")
  groupId    String        @map("group_id")
  type       RequestType
  payload    Json
  status     RequestStatus @default(PENDING)
  reviewedBy String?       @map("reviewed_by")
  createdAt  DateTime      @default(now()) @map("created_at")
  reviewedAt DateTime?     @map("reviewed_at")

  student  User    @relation("RequestStudent", fields: [studentId], references: [id], onDelete: Cascade)
  group    Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  reviewer User?   @relation("RequestReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  excuse   Excuse?

  @@index([studentId])
  @@index([groupId])
  @@index([status])
  @@map("requests")
}

model Excuse {
  id        String   @id @default(ulid())
  studentId String   @map("student_id")
  groupId   String   @map("group_id")
  createdBy String   @map("created_by")
  requestId String?  @unique @map("request_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  student User     @relation("ExcuseStudent", fields: [studentId], references: [id], onDelete: Cascade)
  group   Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator User     @relation("ExcuseCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  request Request? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  @@map("excuses")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  MODERATOR
  STUDENT
}

enum GroupStatus {
  ACTIVE
  INACTIVE
}

enum GroupMemberStatus {
  ACTIVE
  INACTIVE
}

enum WirdStatus {
  ATTENDED
  MISSED
  LATE
}

enum ReadSourceType {
  DEFAULT_GROUP_MATE
  DIFFERENT_GROUP_MATE
  OUTSIDE_GROUP
}

enum RequestType {
  EXCUSE
  ACTIVATION
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Alert {
  id        String   @id @default(ulid())
  studentId String   @map("student_id")
  groupId   String   @map("group_id")
  weekId    String   @map("week_id")
  dayNumber Int      @map("day_number") @db.TinyInt
  createdAt DateTime @default(now()) @map("created_at")

  student User  @relation("AlertStudent", fields: [studentId], references: [id], onDelete: Cascade)
  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  week    Week  @relation(fields: [weekId], references: [id], onDelete: Cascade)

  @@unique([studentId, weekId, dayNumber])
  @@map("alerts")
}

model Notification {
  id          String           @id @default(ulid())
  recipientId String           @map("recipient_id")
  type        NotificationType
  payload     Json
  readAt      DateTime?        @map("read_at")
  createdAt   DateTime         @default(now()) @map("created_at")

  recipient User @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId])
  @@index([recipientId, readAt])
  @@map("notifications")
}

enum NotificationType {
  ALERT_ASSIGNED
  LEARNER_DEACTIVATED
  LEARNER_REMOVED
  REQUEST_CREATED
  REQUEST_UPDATED
}
